# ──────────────────────────────────────────────────────────────────────────────
# Crypto Payments – Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
# "testnet" or "mainnet"
CRYPTO_NETWORK=testnet
CRYPTO_DEFAULT_CURRENCY=BTC

# ── Bitcoin Testnet (signet / testnet4) ───────────────────────────────────────
BTC_TESTNET_RPC=http://localhost:18332
BTC_TESTNET_USER=bitcoin
BTC_TESTNET_PASSWORD=changeme
# Set to false only when using a self-signed certificate on a private RPC node
BTC_TESTNET_VERIFY_SSL=true
# Required confirmations before a payment is considered confirmed
BTC_CONFIRMATIONS=3
# BIP32/44 master seed (hex or mnemonic) – keep secret!
BTC_MASTER_SEED=

# ── Bitcoin Mainnet ───────────────────────────────────────────────────────────
BTC_MAINNET_ENABLED=false
BTC_MAINNET_RPC=
BTC_MAINNET_USER=
BTC_MAINNET_PASSWORD=
BTC_MAINNET_VERIFY_SSL=true

# ── Ethereum Testnet (Sepolia, chain_id 11155111) ─────────────────────────────
ETH_TESTNET_RPC=http://localhost:8545
ETH_CONFIRMATIONS=12

# ── Ethereum Mainnet ──────────────────────────────────────────────────────────
ETH_MAINNET_ENABLED=false
ETH_MAINNET_RPC=

# ── Exchange Rates ────────────────────────────────────────────────────────────
# Supported: coingecko
EXCHANGE_RATES_PROVIDER=coingecko

# ── Monitoring (optional) ─────────────────────────────────────────────────────
CRYPTO_SLACK_WEBHOOK=
